APP_NAME="Kode Mukti Store"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://store.kodemukti.online

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kode_mukti_store
DB_USERNAME=kodemukti
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.store.kodemukti.online

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@store.kodemukti.online"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Product Configuration
PRODUCT_PRICE=99000
PRODUCT_EBOOK_ZIP_PATH=products/Ultimate-ChatGPT-Mastery-Bundle.zip
PRODUCT_LEAD_MAGNET_PATH=lead-magnets/50-prompt-pemasaran-gratis.pdf
PRODUCT_QRIS_IMAGE_PATH=/images/qris.png
PROMO_DEADLINE=2026-07-31

# Admin Credentials (set before running AdminUserSeeder)
ADMIN_EMAIL=admin@store.kodemukti.online
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Cloudflared Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN
